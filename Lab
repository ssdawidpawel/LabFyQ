<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lab DPTO FYQ</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --border: rgba(255,255,255,0.08);
    --accent: #c8ff00;
    --text: #f0efe8;
    --muted: #6b6b7a;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── LOCK SCREEN ── */
  #lock-screen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(200,255,0,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,255,0,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .bg-glow {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,255,0,0.06) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .lock-card {
    position: relative;
    z-index: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 3rem 3rem;
    width: 420px;
    max-width: 92vw;
    text-align: center;
  }

  .lock-icon {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: rgba(200,255,0,0.1);
    border: 1px solid rgba(200,255,0,0.3);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
    font-size: 28px;
  }

  .lock-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 0.4rem;
  }

  .lock-sub {
    font-size: 13px;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    margin-bottom: 2rem;
  }

  .input-wrap {
    position: relative;
    margin-bottom: 1rem;
  }

  .input-wrap input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 48px 14px 18px;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    letter-spacing: 2px;
    outline: none;
    transition: border-color 0.2s;
  }

  .input-wrap input:focus {
    border-color: rgba(200,255,0,0.4);
  }

  .toggle-pw {
    position: absolute; right: 14px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-size: 16px;
    padding: 4px;
  }

  .btn-enter {
    width: 100%;
    background: var(--accent);
    color: #0a0a0f;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    letter-spacing: 0.5px;
  }

  .btn-enter:hover { opacity: 0.9; }
  .btn-enter:active { transform: scale(0.98); }

  .error-msg {
    margin-top: 0.75rem;
    font-size: 12px;
    font-family: 'Space Mono', monospace;
    color: #ff5c5c;
    min-height: 18px;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .error-msg.show { opacity: 1; }

  /* shake animation */
  @keyframes shake {
    0%,100%{transform:translateX(0)}
    20%{transform:translateX(-8px)}
    40%{transform:translateX(8px)}
    60%{transform:translateX(-5px)}
    80%{transform:translateX(5px)}
  }
  .shake { animation: shake 0.4s ease; }

  /* ── CONTENT ── */
  #content {
    display: none;
    min-height: 100vh;
    padding: 3rem 2rem 4rem;
    max-width: 960px;
    margin: 0 auto;
  }

  #content.visible { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    animation: fadeUp 0.5s ease both;
  }

  .page-header h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1.1;
  }

  .page-header h1 span { color: var(--accent); }

  .page-header p {
    margin-top: 0.75rem;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ── BOXES GRID ── */
  .boxes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 3rem;
  }

  .box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    text-align: center;
    cursor: default;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    animation: fadeUp 0.5s ease both;
    position: relative;
    overflow: hidden;
  }

  .box:hover { transform: translateY(-6px) scale(1.02); }

  .box-label {
    font-size: 11px;
    font-family: 'Space Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.5rem;
    opacity: 0.75;
  }

  .box-name {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .box-weight {
    font-family: 'Space Mono', monospace;
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
  }

  .box-unit {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    margin-top: 4px;
    opacity: 0.6;
  }

  /* individual box styles */
  .box-1 {
    background: #0d2a4a;
    border: 1px solid #1a5f9e;
    border-radius: 50%;
    aspect-ratio: 1;
    color: #7ec8f0;
  }

  .box-2 {
    background: #082a1a;
    border: 2px solid #1a9e60;
    border-radius: 16px;
    color: #5de8a8;
  }

  .box-3 {
    background: #1e0a3a;
    border: 1px solid #7a3fe0;
    border-radius: 4px;
    transform: rotate(-2deg);
    color: #c49ef5;
  }

  .box-3:hover { transform: rotate(-2deg) translateY(-6px) scale(1.02); }

  .box-4 {
    background: #2a1a00;
    border: 2px solid #e09020;
    border-radius: 0;
    color: #f5c060;
  }

  .box-5 {
    background: #2a0a20;
    border: 1px solid #d04090;
    border-radius: 32px 0 32px 0;
    color: #f090c0;
  }

  .box-6 {
    background: #0a2a0a;
    border: 2px dashed #40c040;
    border-radius: 12px;
    color: #80e880;
  }

  .box-7 {
    background: #2a0808;
    border: 1px solid #c04040;
    border-radius: 0;
    clip-path: polygon(12px 0%, 100% 0%, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0% 100%, 0% 12px);
    color: #f08080;
  }

  .box-8 {
    background: #1a1a1a;
    border: 2px dotted #888;
    border-radius: 12px;
    color: #c0c0c0;
  }

  /* ── NOTA ── */
  .nota {
    background: #1a0808;
    border: 1px solid #c04040;
    border-radius: 16px;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    animation: fadeUp 0.5s ease 0.4s both;
  }

  .nota-icon {
    font-size: 24px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .nota-text {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
    color: #f0a0a0;
  }

  .nota-text strong {
    color: #ff5c5c;
    font-weight: 700;
  }

  .nota-amount {
    display: inline-block;
    background: rgba(255,92,92,0.2);
    border: 1px solid rgba(255,92,92,0.4);
    border-radius: 6px;
    padding: 2px 8px;
    font-weight: 700;
    color: #ff5c5c;
  }
</style>
</head>
<body>

<!-- LOCK SCREEN -->
<div id="lock-screen">
  <div class="bg-grid"></div>
  <div class="bg-glow"></div>

  <div class="lock-card">
    <div class="lock-icon">🔬</div>
    <div class="lock-title">DPTO FYQ</div>
    <div class="lock-sub">// acceso restringido</div>

    <div class="input-wrap">
      <input type="password" id="pw-input" placeholder="Contraseña..." autocomplete="off" />
      <button class="toggle-pw" id="toggle-pw" tabindex="-1" title="Mostrar/ocultar">👁</button>
    </div>

    <button class="btn-enter" id="btn-enter">Acceder →</button>
    <div class="error-msg" id="error-msg">Contraseña incorrecta</div>
  </div>
</div>

<!-- CONTENT -->
<div id="content">
  <div class="page-header">
    <h1>Inventario <span>Laboratorio</span></h1>
    <p>DPTO FYQ — Registro de compuestos</p>
  </div>

  <div class="boxes-grid">

    <div class="box box-1" style="animation-delay:0.05s">
      <div class="box-label">01</div>
      <div class="box-name">Metanol</div>
      <div class="box-weight">100</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-2" style="animation-delay:0.10s">
      <div class="box-label">02</div>
      <div class="box-name">Agua destilada</div>
      <div class="box-weight">1000</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-3" style="animation-delay:0.15s">
      <div class="box-label">03</div>
      <div class="box-name">Alcohol etílico</div>
      <div class="box-weight">1000</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-4" style="animation-delay:0.20s">
      <div class="box-label">04</div>
      <div class="box-name">Solución salina</div>
      <div class="box-weight">495</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-5" style="animation-delay:0.25s">
      <div class="box-label">05</div>
      <div class="box-name">Acetona</div>
      <div class="box-weight">30</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-6" style="animation-delay:0.30s">
      <div class="box-label">06</div>
      <div class="box-name">KCN</div>
      <div class="box-weight">22</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-7" style="animation-delay:0.35s">
      <div class="box-label">07</div>
      <div class="box-name">Sales de arsénico</div>
      <div class="box-weight">234</div>
      <div class="box-unit">gramos</div>
    </div>

    <div class="box box-8" style="animation-delay:0.40s">
      <div class="box-label">08</div>
      <div class="box-name">Benzodiacepinas</div>
      <div class="box-weight">1032</div>
      <div class="box-unit">gramos</div>
    </div>

  </div>

  <div class="nota">
    <div class="nota-icon">⚠️</div>
    <div class="nota-text">
      <strong>Rocío</strong>, el uso anormal de productos del laboratorio
      serán descontados de tu sueldo <span class="nota-amount">-203€</span>
    </div>
  </div>
</div>

<script>
  const PASSWORD = 'Rocio2034_DPTOFYQ';
  const pwInput = document.getElementById('pw-input');
  const btnEnter = document.getElementById('btn-enter');
  const errorMsg = document.getElementById('error-msg');
  const togglePw = document.getElementById('toggle-pw');
  const lockScreen = document.getElementById('lock-screen');
  const content = document.getElementById('content');

  function tryUnlock() {
    if (pwInput.value === PASSWORD) {
      lockScreen.style.transition = 'opacity 0.4s ease';
      lockScreen.style.opacity = '0';
      setTimeout(() => {
        lockScreen.style.display = 'none';
        content.classList.add('visible');
      }, 400);
    } else {
      errorMsg.classList.add('show');
      pwInput.classList.add('shake');
      pwInput.value = '';
      setTimeout(() => pwInput.classList.remove('shake'), 400);
      setTimeout(() => errorMsg.classList.remove('show'), 2500);
    }
  }

  btnEnter.addEventListener('click', tryUnlock);
  pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') tryUnlock(); });

  togglePw.addEventListener('click', () => {
    pwInput.type = pwInput.type === 'password' ? 'text' : 'password';
  });
</script>
</body>
</html>
